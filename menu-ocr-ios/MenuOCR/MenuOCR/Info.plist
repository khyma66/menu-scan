<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- App Identity -->
    <key>CFBundleName</key>
    <string>Fooder</string>

    <key>CFBundleDisplayName</key>
    <string>Fooder</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- Privacy – Usage Description Strings (REQUIRED by App Store) -->

    <key>NSCameraUsageDescription</key>
    <string>Fooder uses your camera to photograph restaurant menus so it can scan and translate dish names, descriptions, and prices for you.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>Fooder reads photos from your library so you can scan a menu image you have already saved.</string>

    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Fooder can save annotated menu images to your photo library so you can reference them later.</string>

    <!-- App Tracking Transparency -->
    <key>NSUserTrackingUsageDescription</key>
    <string>Fooder uses anonymous usage data to improve scan accuracy and app performance. No personal information is shared with third parties for advertising purposes.</string>

    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

</dict>
</plist>
