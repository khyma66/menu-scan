<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ============================================================ -->
    <!-- App Identity                                                 -->
    <!-- ============================================================ -->
    <key>CFBundleName</key>
    <string>Fooder</string>

    <key>CFBundleDisplayName</key>
    <string>Fooder</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- ============================================================ -->
    <!-- Privacy – Usage Description Strings (REQUIRED by App Store)  -->
    <!-- Missing any of these = guaranteed rejection                  -->
    <!-- ============================================================ -->

    <!-- Camera: used to photograph restaurant menus -->
    <key>NSCameraUsageDescription</key>
    <string>Fooder uses your camera to photograph restaurant menus so it can scan and translate dish names, descriptions, and prices for you.</string>

    <!-- Photo Library read-access: user selects existing menu photos -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Fooder reads photos from your library so you can scan a menu image you have already saved.</string>

    <!-- Photo Library write-access: only required if you save processed images back -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Fooder can save annotated menu images to your photo library so you can reference them later.</string>

    <!-- Location (future map / nearby-restaurant feature) -->
    <!-- Remove this key entirely if location is not yet used in the current build -->
    <!-- <key>NSLocationWhenInUseUsageDescription</key> -->
    <!-- <string>Fooder uses your location to show nearby restaurants and match menus to the right venue.</string> -->

    <!-- ============================================================ -->
    <!-- App Tracking Transparency (ATT) – REQUIRED if analytics     -->
    <!-- are enabled or any advertising identifier is read            -->
    <!-- ============================================================ -->
    <key>NSUserTrackingUsageDescription</key>
    <string>Fooder uses anonymous usage data to improve scan accuracy and app performance. No personal information is shared with third parties for advertising purposes.</string>

    <!-- ============================================================ -->
    <!-- App Transport Security                                       -->
    <!-- ============================================================ -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- All production endpoints (Cloudflare Worker, Supabase) use HTTPS  -->
        <!-- Only allow localhost for DEBUG simulator builds                   -->
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <!-- Localhost exception is stripped from App Store builds     -->
                <!-- via a build-time script; production traffic is HTTPS only -->
            </dict>
        </dict>
    </dict>

    <!-- ============================================================ -->
    <!-- Scene & UI                                                   -->
    <!-- ============================================================ -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default Configuration</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
                </dict>
            </array>
        </dict>
    </dict>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIRequiresFullScreen</key>
    <false/>

    <!-- ============================================================ -->
    <!-- Minimum iOS version (matches Xcode Deployment Target)        -->
    <!-- ============================================================ -->
    <key>MinimumOSVersion</key>
    <string>16.0</string>

</dict>
</plist>
