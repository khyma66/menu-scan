<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".LoginActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Logo and App Name -->
            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="96dp"
                android:layout_height="108dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="8dp"
                android:src="@drawable/ic_app_logo"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="@string/app_name"
                android:textColor="#222222"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Login Form -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Tab Layout for Login/Signup -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp"
                        android:background="@color/gray_100"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/loginTab"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Login"
                            android:textColor="@color/gray_900"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:background="@color/white" />

                        <TextView
                            android:id="@+id/signupTab"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Sign Up"
                            android:textColor="@color/gray_text"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:background="@color/gray_100" />
                    </LinearLayout>

                    <!-- Email Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="#999999"
                        app:hintTextColor="#666666">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/emailInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email"
                            android:inputType="textEmailAddress"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="#999999"
                        app:hintTextColor="#666666"
                        app:passwordToggleEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/passwordInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Password"
                            android:inputType="textPassword"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password (for signup) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/confirmPasswordLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="#999999"
                        app:hintTextColor="#666666"
                        app:passwordToggleEnabled="true"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/confirmPasswordInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Confirm Password"
                            android:inputType="textPassword"
                            android:textSize="16sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Forgot Password (for login) -->
                    <TextView
                        android:id="@+id/forgotPasswordText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forgot Password?"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:layout_gravity="end"
                        android:layout_marginBottom="24dp"
                        android:padding="4dp"
                        android:background="?attr/selectableItemBackground" />

                    <!-- Login/Signup Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/submitButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Login"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp"
                        android:backgroundTint="#222222"
                        app:strokeWidth="0dp" />

                    <!-- Loading Progress -->
                    <ProgressBar
                        android:id="@+id/loadingProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:visibility="gone" />

                    <!-- Error Message -->
                    <TextView
                        android:id="@+id/errorText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#D32F2F"
                        android:textSize="14sp"
                        android:gravity="start"
                        android:layout_marginTop="12dp"
                        android:visibility="gone" />

                    <!-- Divider -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="or continue with"
                            android:textColor="#999999"
                            android:textSize="12sp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0" />

                    </LinearLayout>

                    <!-- Social Login Buttons: full-width stacked for clarity -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/googleSignInButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="10dp"
                        android:text="Continue with Google"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        app:icon="@drawable/ic_google"
                        app:iconPadding="12dp"
                        app:iconGravity="textStart"
                        app:iconTint="@null"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/white"
                        app:strokeColor="#DADDE3"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/appleSignInButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Continue with Apple"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="#1A1A1A"
                        app:strokeWidth="0dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Skip Login -->
            <TextView
                android:id="@+id/skipLoginText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skip for now"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
