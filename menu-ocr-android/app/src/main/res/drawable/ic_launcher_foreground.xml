<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher foreground – pixel-perfect match to ic_nav_discover.xml.
    Source artwork is drawn on a 28×28 viewport.
    Here it is scaled ×2.571 (= 72÷28) and translated 18dp so it sits
    perfectly inside the 72dp adaptive-icon safe zone of the 108dp canvas.

    Transform maths (VectorDrawable group order: scale around pivot then translate):
      pivot default = (0,0) → point (x,y) maps to (x×2.571 + 18 , y×2.571 + 18)
      content spans x: 3→25, y: 3→27  →  after transform: x: 25.7→82.3, y: 25.7→87.4
      all well within the 108dp canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:scaleX="2.571"
        android:scaleY="2.571"
        android:translateX="18"
        android:translateY="18">

        <!-- Tomato body – centre (14,16) radius 11 -->
        <path
            android:fillColor="#E8341A"
            android:pathData="M 3,16 A 11,11 0 1 0 25,16 A 11,11 0 1 0 3,16 Z"
            android:strokeColor="#1A1A1A"
            android:strokeWidth="1.4" />

        <!-- Leaf / calyx -->
        <path
            android:fillColor="#5BA01E"
            android:pathData="M 14,7.5
                              Q 11,5 7,7.5
                              Q 11,10.5 14,9
                              Q 17,10.5 21,7.5
                              Q 17,5 14,7.5 Z"
            android:strokeColor="#1A1A1A"
            android:strokeWidth="1.0"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />

        <!-- Stem – dark outline then green fill on top -->
        <path
            android:fillColor="#00000000"
            android:pathData="M 14,3 L 14,7.5"
            android:strokeColor="#1A1A1A"
            android:strokeWidth="1.8"
            android:strokeLineCap="round" />
        <path
            android:fillColor="#00000000"
            android:pathData="M 14,3 L 14,7.5"
            android:strokeColor="#5BA01E"
            android:strokeWidth="1.0"
            android:strokeLineCap="round" />

        <!-- Left eye sclera – centre (10.2, 13.8) radius 2.75 -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 7.45,13.8 A 2.75,2.75 0 1 0 12.95,13.8 A 2.75,2.75 0 1 0 7.45,13.8 Z"
            android:strokeColor="#1A1A1A"
            android:strokeWidth="0.6" />

        <!-- Right eye sclera – centre (17.8, 13.8) radius 2.75 -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 15.05,13.8 A 2.75,2.75 0 1 0 20.55,13.8 A 2.75,2.75 0 1 0 15.05,13.8 Z"
            android:strokeColor="#1A1A1A"
            android:strokeWidth="0.6" />

        <!-- Left pupil – centre (10.2, 13.8) radius 1.1 -->
        <path
            android:fillColor="#1A1A1A"
            android:pathData="M 9.1,13.8 A 1.1,1.1 0 1 0 11.3,13.8 A 1.1,1.1 0 1 0 9.1,13.8 Z" />

        <!-- Right pupil – centre (17.8, 13.8) radius 1.1 -->
        <path
            android:fillColor="#1A1A1A"
            android:pathData="M 16.7,13.8 A 1.1,1.1 0 1 0 18.9,13.8 A 1.1,1.1 0 1 0 16.7,13.8 Z" />

        <!-- Smile arc -->
        <path
            android:fillColor="#00000000"
            android:pathData="M 10.5,19.5 Q 14,23 17.5,19.5"
            android:strokeColor="#1A1A1A"
            android:strokeWidth="1.0"
            android:strokeLineCap="round" />

    </group>

</vector>
