<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher foreground – cute tomato mascot with light-black border.
    Viewport 28×28 scaled to fill the 108dp adaptive-icon canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:scaleX="2.571"
        android:scaleY="2.571"
        android:translateX="18"
        android:translateY="18">

        <!-- Tomato body – bright red with light-black border -->
        <path
            android:fillColor="#ED1C24"
            android:pathData="M 3,16 A 11,11 0 1 0 25,16 A 11,11 0 1 0 3,16 Z"
            android:strokeColor="#2D2D2D"
            android:strokeWidth="1.6" />

        <!-- Leaf / calyx – wider, matching image -->
        <path
            android:fillColor="#4CA621"
            android:pathData="M 14,7.5
                              Q 10.5,4.5 6,7.5
                              Q 10.5,11 14,9.2
                              Q 17.5,11 22,7.5
                              Q 17.5,4.5 14,7.5 Z"
            android:strokeColor="#2D2D2D"
            android:strokeWidth="1.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />

        <!-- Stem – dark outline then green fill -->
        <path
            android:fillColor="#00000000"
            android:pathData="M 14,3 L 14,7.5"
            android:strokeColor="#2D2D2D"
            android:strokeWidth="2.2"
            android:strokeLineCap="round" />
        <path
            android:fillColor="#00000000"
            android:pathData="M 14,3 L 14,7.5"
            android:strokeColor="#4CA621"
            android:strokeWidth="1.2"
            android:strokeLineCap="round" />

        <!-- Left eye sclera – bigger, centre (10.2, 14) radius 3.0 -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 7.2,14 A 3.0,3.0 0 1 0 13.2,14 A 3.0,3.0 0 1 0 7.2,14 Z"
            android:strokeColor="#2D2D2D"
            android:strokeWidth="0.9" />

        <!-- Right eye sclera – centre (17.8, 14) radius 3.0 -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M 14.8,14 A 3.0,3.0 0 1 0 20.8,14 A 3.0,3.0 0 1 0 14.8,14 Z"
            android:strokeColor="#2D2D2D"
            android:strokeWidth="0.9" />

        <!-- Left pupil – centre (10.2, 14) radius 1.3 -->
        <path
            android:fillColor="#2D2D2D"
            android:pathData="M 8.9,14 A 1.3,1.3 0 1 0 11.5,14 A 1.3,1.3 0 1 0 8.9,14 Z" />

        <!-- Right pupil – centre (17.8, 14) radius 1.3 -->
        <path
            android:fillColor="#2D2D2D"
            android:pathData="M 16.5,14 A 1.3,1.3 0 1 0 19.1,14 A 1.3,1.3 0 1 0 16.5,14 Z" />

        <!-- Smile arc – wider, friendlier -->
        <path
            android:fillColor="#00000000"
            android:pathData="M 10,19.5 Q 14,23.5 18,19.5"
            android:strokeColor="#2D2D2D"
            android:strokeWidth="1.1"
            android:strokeLineCap="round" />

    </group>

</vector>
