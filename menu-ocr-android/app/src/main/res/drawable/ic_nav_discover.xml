<?xml version="1.0" encoding="utf-8"?>
<!--
    Fooder tomato mascot — matches the brand reference image exactly:
    • Very thick dark outline on body (~2.5 viewport units)
    • Leaf wings: two symmetric lobes + outlined green stem
    • Eyes: large white sclera circles, pupils CENTRED (no offset)
    • Smile arc in lower half
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="28"
    android:viewportHeight="28">

    <!--
        Tomato body
        centre (14, 16), radius 11
        path: M (14-11),16  arc to (14+11),16  arc back
    -->
    <path
        android:fillColor="#E8341A"
        android:pathData="M 3,16 A 11,11 0 1 0 25,16 A 11,11 0 1 0 3,16 Z"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="1.4" />

    <!--
        Leaf / calyx — two wing lobes pinched at centre
        Shape: from centre (14,7.5) sweep out to left tip, back through
        lower-centre, out to right tip, and close at top-centre.
    -->
    <path
        android:fillColor="#5BA01E"
        android:pathData="M 14,7.5
                          Q 11,5 7,7.5
                          Q 11,10.5 14,9
                          Q 17,10.5 21,7.5
                          Q 17,5 14,7.5 Z"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="1.0"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!--
        Stem — dark outline (wider) drawn first, green fill (narrower) on top
        to produce a green stem with dark side-borders.
    -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 14,3 L 14,7.5"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />
    <path
        android:fillColor="#00000000"
        android:pathData="M 14,3 L 14,7.5"
        android:strokeColor="#5BA01E"
        android:strokeWidth="1.0"
        android:strokeLineCap="round" />

    <!--
        Left eye sclera
        centre (10.2, 13.8), radius 2.75
        path: M (10.2-2.75), 13.8 = M 7.45, 13.8
              A 2.75,2.75 0 1 0 (10.2+2.75), 13.8 = 12.95, 13.8
              A 2.75,2.75 0 1 0 7.45, 13.8 Z
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 7.45,13.8 A 2.75,2.75 0 1 0 12.95,13.8 A 2.75,2.75 0 1 0 7.45,13.8 Z"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="0.6" />

    <!--
        Right eye sclera
        centre (17.8, 13.8), radius 2.75
        path: M 15.05, 13.8 … 20.55, 13.8
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 15.05,13.8 A 2.75,2.75 0 1 0 20.55,13.8 A 2.75,2.75 0 1 0 15.05,13.8 Z"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="0.6" />

    <!--
        Left pupil — centre (10.2, 13.8), radius 1.1
        path: M (10.2-1.1), 13.8 = M 9.1, 13.8
              A 1.1,1.1 0 1 0 11.3, 13.8
              A 1.1,1.1 0 1 0 9.1, 13.8 Z
    -->
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M 9.1,13.8 A 1.1,1.1 0 1 0 11.3,13.8 A 1.1,1.1 0 1 0 9.1,13.8 Z" />

    <!--
        Right pupil — centre (17.8, 13.8), radius 1.1
        path: M 16.7, 13.8 … 18.9, 13.8
    -->
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M 16.7,13.8 A 1.1,1.1 0 1 0 18.9,13.8 A 1.1,1.1 0 1 0 16.7,13.8 Z" />

    <!--
        Smile arc — gentle quadratic bezier curve below the eyes
    -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 10.5,19.5 Q 14,23 17.5,19.5"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="1.0"
        android:strokeLineCap="round" />

</vector>
